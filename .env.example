# Stack metadata
STACK_NAME=Enshrouded Stack
TZ=Etc/UTC

# Project images. Pin all four to the same immutable main-<sha> or release version in production.
SERVER_IMAGE=powermountain/enshrouded-dedi-server:latest
BACKUP_IMAGE=powermountain/enshrouded-dedi-backup:latest
UI_IMAGE=powermountain/enshrouded-dedi-ui:latest
CONTROLLER_IMAGE=powermountain/enshrouded-dedi-controller:latest

# Admin UI
UI_ADMIN_USERNAME=admin
UI_ADMIN_PASSWORD=changeme
UI_SESSION_SECRET=please-change-me
UI_SESSION_ENCRYPTION_KEY=please-change-me-32-bytes-long!!
UI_CSRF_KEY=please-change-me-csrf-key-32-bytes
UI_SECURE_COOKIES=false
UI_SESSION_HOURS=24
BACKUP_API_URL=http://backup:7000
UI_SERVER_NAME=My Enshrouded Server
UI_LOGO_URL=/static/logo.svg
A2S_ENABLED=true
A2S_ADDR=enshrouded:15637
A2S_TIMEOUT_MS=1500
A2S_CACHE_SECONDS=10
BACKUP_INTERNAL_TOKEN=please-change-me-internal-token-32
DOCKER_CONTROLLER_TOKEN=please-change-me-controller-token
ALLOW_INSECURE_DEFAULTS=false

# Enshrouded server (first-boot defaults; editable later via UI)
SERVER_NAME=My Enshrouded Server
MAX_PLAYERS=16
GAME_PORT=15636
QUERY_PORT=15637
GAME_HOST_PORT=15636
QUERY_HOST_PORT=15637
SAVE_DIR=/data/savegame
UPDATE_ON_START=true
UI_HOST_BIND=0.0.0.0
UI_HOST_PORT=8080

# Backup service
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAILIES=14
BACKUP_RETENTION_WEEKLIES=8
BACKUP_RETENTION_MONTHLIES=12
BACKUP_SAVE_DIR=/data/savegame
BACKUP_SERVER_CONFIG_PATH=/data/server/enshrouded_server.json
BACKUP_SERVER_CONFIG_TXT_PATH=/data/server/server_config.txt
BACKUP_LOG_DIR=/data/server/logs
BACKUP_STEAM_AUTH_FILE=/data/steam_auth.env
BACKUP_STEAM_APP_MANIFEST=/data/server/steamapps/appmanifest_2278520.acf
BACKUP_MAX_EXTRACT_FILES=10000
BACKUP_MAX_EXTRACT_BYTES=4294967296
BACKUP_HEALTH_TIMEOUT_SECONDS=900
BACKUP_BIND_ADDR=0.0.0.0:7000
ENSHROUDED_CONTAINER_NAME=enshrouded
BACKUP_LOG_LEVEL=info
BACKUP_AUDIT_PATH=/data/control/audit.jsonl
# Optional generic JSON webhook for operation completion/failure notifications.
BACKUP_NOTIFICATION_WEBHOOK_URL=
# Optional restart safety. When enabled, restart/config/update jobs fail while players are online.
BACKUP_A2S_ADDR=enshrouded:15637
BACKUP_A2S_TIMEOUT_MS=2000
BACKUP_RESTART_REQUIRE_EMPTY=false
# Optional HH:MM-HH:MM window in TZ; applies to update jobs and supports overnight windows.
BACKUP_MAINTENANCE_WINDOW=
# Webhook-only online/offline transition notifications.
BACKUP_PLAYER_NOTIFICATIONS=false
BACKUP_PLAYER_POLL_SECONDS=60

# Optional container resource ceilings
SERVER_MEMORY_LIMIT=16g
SERVER_CPU_LIMIT=6
BACKUP_MEMORY_LIMIT=1g
BACKUP_CPU_LIMIT=1
UI_MEMORY_LIMIT=256m
UI_CPU_LIMIT=0.5
MINIO_MEMORY_LIMIT=2g
MINIO_CPU_LIMIT=2
CONTROLLER_MEMORY_LIMIT=128m
CONTROLLER_CPU_LIMIT=0.25

# MinIO / S3
MINIO_ROOT_USER=enshrouded
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=enshrouded-backups
MINIO_RETENTION_DAYS=180
MINIO_REGION=us-east-1
MINIO_CONSOLE_HOST_BIND=127.0.0.1
MINIO_CONSOLE_HOST_PORT=9001
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
BACKUP_S3_ENDPOINT=http://minio:9000
BACKUP_S3_ACCESS_KEY=enshrouded
BACKUP_S3_SECRET_KEY=changeme
BACKUP_S3_BUCKET=enshrouded-backups
BACKUP_S3_SSL=false
